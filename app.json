{
  "expo": {
    "name": "Inventra",
    "slug": "Inventra",
    "version": "1.0.1",
    "orientation": "default",
    "icon": "./assets/images/inventra_logo.png",
    "scheme": "inventra",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "icon": "./assets/images/inventra_logo.png",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.dreedeve.Inventra"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/inventra_logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Inventra_frontlogo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    }
  }
}
